# jia configuration
# Copy to .env to override CLI args
JIA_HOST=127.0.0.1
JIA_PORT=3000

# Config file path (default: ./jia.toml)
# JIA_CONFIG=/path/to/jia.toml

# --- API Keys ---
# Override or set the API token for dashboard auth (auto-generated if absent)
# JIA_API_KEY=sk-...

# Per-provider API keys (overrides config.toml)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# GEMINI_API_KEY=...
# OLLAMA_API_KEY=...

# --- Data directory ---
# Override default ~/.jia
# JIA_HOME=/path/to/data

# --- Bots ---
# Set to any value to disable all IM bots
# JIA_SKIP_BOTS=1

# --- Logging ---
# RUST_LOG=jia=info,tower_http=info
